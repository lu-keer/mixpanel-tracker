{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@mixchunk/mixpanel-tracker": ["../../src/index.ts"],
      "@mixchunk/mixpanel-tracker/vue": ["../../src/integrations/vue.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}